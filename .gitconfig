[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[user]
	name = Antonio Nuno Monteiro
	email = anmonteiro@gmail.com
[color "diff"]
	whitespace = bold red reverse
[diff]
	wserrorhighlight = all
[pull]
	rebase = false
[core]
	fscache = true
	fsmonitor = true
	untrackedCache = true
[feature]
	manyFiles = true
[gc]
	writeCommitGraph = true
[fetch]
	writeCommitGraph = true
	fsmonitor = true
[gc]
	writeCommitGraph = true
[fetch]
	writeCommitGraph = true
